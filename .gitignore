# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# TLS certificates (generated locally)
certs/

# sqlite database
prisma/dev.db
prisma/dev.db.bak

# mcp server build output & deps
mcp/dist/
mcp/node_modules/
ubuntu-ca.crt

# User store — contains auth tokens, never commit
data/users.json
# Pending invite codes — time-limited, never commit
data/invites.json

# Dev-only Claude Code hook (contains local server IP)
.claude/settings.json

# Auto-generated macOS launchd plist (contains local home paths)
com.luchegames.2dobetter.plist

# claude-runner config — contains agent token, never commit
.claude-dispatch.json
.claude-runner.json
.claude-runner-sessions.json
# LaunchAgent plist — contains local paths, generated per machine
com.2dobetter.dispatch.plist
com.2dobetter.runner.plist
