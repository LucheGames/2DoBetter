# Cerebras API key — free at https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_key_here

# 2Do Better server URL
API_BASE_URL=https://localhost:3000

# Agent token from the board (hold "+ Agent" button)
AGENT_TOKEN=your_token_here

# Optional overrides
# CEREBRAS_MODEL=llama-3.3-70b   # default — check https://cloud.cerebras.ai/platform for current models
# AGENT_NAME=Cerebras             # must match your column owner username exactly
