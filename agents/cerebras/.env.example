# Cerebras API key — free at https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_key_here

# 2Do Better server URL (use your DuckDNS domain for proper TLS)
API_BASE_URL=https://yourname.duckdns.org:3000

# Agent token from the board (hold "+ Agent" button)
AGENT_TOKEN=your_token_here

# Optional overrides
# CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507   # default — Qwen 3 235B MoE, frontier quality, 65k ctx
# CEREBRAS_MODEL=llama3.1-8b                      # faster/lighter fallback, 8k ctx
# AGENT_NAME=Cerebras             # must match your column owner username exactly
