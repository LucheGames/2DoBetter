# 2Do Better server URL (no trailing slash)
# Use your DuckDNS domain for proper TLS — see README Remote Access section
API_BASE_URL=https://yourname.duckdns.org:3000

# Agent token from the admin panel (+ Agent button → copy token shown on creation)
AGENT_TOKEN=your_agent_token_here

# Optional: Ollama server address (default: http://localhost:11434)
# Change this if Ollama runs on a different machine
# OLLAMA_HOST=http://localhost:11434

# Optional: override the model (default: qwen2.5-32k)
# Default assumes you ran setup: ollama create qwen2.5-32k -f Modelfile (see README)
# OLLAMA_MODEL=qwen2.5:14b  # also needs a 32k variant — see README

# Optional: name shown in the system prompt (default: Ollama)
# AGENT_NAME=Jarvis

# Optional: set to 1 for verbose tool call logging
# DEBUG=1
