# Gemini API key — get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 2Do Better server URL (no trailing slash)
API_BASE_URL=https://yourname.duckdns.org:3000

# Agent token from the admin panel (Settings ⚙ → your agent's column → rotate token)
AGENT_TOKEN=your_agent_token_here

# Optional: name shown in the system prompt (default: Gemini)
# AGENT_NAME=Jarvis

# Optional: set to 1 for verbose tool call logging
# DEBUG=1
