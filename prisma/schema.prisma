generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Column {
  id            Int      @id @default(autoincrement())
  name          String
  slug          String   @unique
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  ownerUsername String?
  locked        Boolean  @default(false)
  lists         List[]

  @@index([ownerUsername])
}

model List {
  id         Int       @id @default(autoincrement())
  columnId   Int
  parentId   Int?
  name       String
  order      Int       @default(0)
  createdAt  DateTime  @default(now())
  archivedAt DateTime?

  column   Column @relation(fields: [columnId], references: [id], onDelete: Cascade)
  parent   List?  @relation("ListToSubList", fields: [parentId], references: [id], onDelete: Cascade)
  children List[] @relation("ListToSubList")
  tasks    Task[]

  @@index([columnId])
  @@index([parentId])
}

model Task {
  id                  Int       @id @default(autoincrement())
  listId              Int
  title               String
  completed           Boolean   @default(false)
  completedAt         DateTime?
  completedBreadcrumb String?
  createdBy           String?
  order               Int       @default(0)
  createdAt           DateTime  @default(now())

  list List @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
}
