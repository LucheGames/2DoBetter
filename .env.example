# ── Server ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# ── Auth ────────────────────────────────────────────────────────────────────────
# Set to any non-empty value to enable user registration via invite codes.
# Actual codes are time-limited PINs generated in the admin panel or via CLI.
INVITE_CODE=enabled

# ── TLS ─────────────────────────────────────────────────────────────────────────
# Directory containing server.crt + server.key
# Auto-generated by `npm run setup` — never commit the certs/ directory
CERT_DIR=./certs

# ── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"
