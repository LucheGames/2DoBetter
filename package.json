{
  "name": "2dobetter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "node scripts/setup.js",
    "add-user": "node scripts/setup.js add-user",
    "remove-user": "node scripts/setup.js remove-user",
    "admin": "node scripts/admin.js",
    "status": "node scripts/admin.js status",
    "list-users": "node scripts/admin.js list-users",
    "context": "node scripts/admin.js context",
    "gen-invite": "node scripts/admin.js gen-invite",
    "export-data": "node scripts/admin.js export-data",
    "import-data": "node scripts/admin.js import-data",
    "purge-completed": "node scripts/admin.js purge-completed",
    "restart": "node scripts/admin.js restart",
    "dev": "next dev --webpack",
    "build": "bash scripts/build.sh",
    "start": "node server.js",
    "seed": "npx tsx prisma/seed.ts",
    "service:install": "cp com.luchegames.2dobetter.plist ~/Library/LaunchAgents/ && launchctl load ~/Library/LaunchAgents/com.luchegames.2dobetter.plist",
    "service:uninstall": "launchctl unload ~/Library/LaunchAgents/com.luchegames.2dobetter.plist && rm ~/Library/LaunchAgents/com.luchegames.2dobetter.plist",
    "service:restart": "launchctl kickstart -k gui/$(id -u)/com.luchegames.2dobetter"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.19.2",
    "dotenv": "^17.3.1",
    "next": "16.1.6",
    "prisma": "^6.19.2",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "description": "Self-hosted, privacy-first todo app. Real-time sync, PWA, no cloud lock-in."
}
